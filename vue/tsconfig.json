{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "target": "es2020",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "strict": true,
    "declaration": true,
    "skipLibCheck": true,
    "incremental": false,
    "lib": ["dom", "dom.iterable", "esnext"]
  },
  "include": ["src"]
}