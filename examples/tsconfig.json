{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    
    "paths": {
      "@l2c/range-kit-core": ["../packages/core/src/index.ts"],
      "@l2c/range-kit-vue": ["../packages/vue/src/index.ts"],
      "@l2c/range-kit-react": ["../packages/react/src/index.ts"]
    }
  },
  "include": ["vue-demo/**/*.ts", "vue-demo/**/*.tsx", "vue-demo/**/*.vue", "react-demo/**/*.ts", "react-demo/**/*.tsx"]
}
