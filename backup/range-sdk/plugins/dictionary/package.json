{
  "name": "@ad-audit/range-sdk-plugin-dictionary",
  "version": "1.0.1-beta.13",
  "description": "词典插件，用于在选中文本时显示词典卡片",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "vite build --config vite.config.ts --watch=false",
    "build:watch": "vite build --config vite.config.ts",
    "dev": "vite build --config vite.config.ts --watch",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "keywords": [
    "range-sdk",
    "plugin",
    "dictionary",
    "词典"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "vue": "^3.0.0",
    "@ad-audit/range-sdk": "workspace:*",
    "element-plus": "^2.0.0",
    "@ad-audit/orz-ui-next": "^4.25.3",
    "canvas-confetti": "^1.9.3",
    "@icon-park/vue-next": "^1.4.2"
  },
  "devDependencies": {
    "@types/node": "18.19.3",
    "@vitejs/plugin-vue": "4.5.0",
    "@vue/compiler-sfc": "3.3.8",
    "typescript": "4.9.5",
    "vite": "4.5.0",
    "vite-plugin-dts": "3.7.0",
    "vitest": "0.34.6",
    "vue": "3.3.8",
    "eslint-plugin-bes": "workspace:*",
    "sass": "1.69.5"
  }
}
